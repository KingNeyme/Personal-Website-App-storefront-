{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/cms",
      "destination": "/cms/index.html"
    },
    {
      "source": "/cms/",
      "destination": "/cms/index.html"
    },
    {
      "source": "/cms/app",
      "destination": "/cms/app/index.html"
    },
    {
      "source": "/cms/app/",
      "destination": "/cms/app/index.html"
    }
  ],
  "headers": [
    {
      "source": "/content/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
